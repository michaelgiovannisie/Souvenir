# Copy this file to .env and fill in your values
# Never commit .env to source control

# JWT — generate a strong secret: openssl rand -base64 64
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-256-bits

# Cloudinary — https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Database (only needed if overriding docker-compose defaults)
# DB_USERNAME=souvenir
# DB_PASSWORD=souvenir
